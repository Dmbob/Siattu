// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ServiceProvider {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  firstName String
  lastName  String
  address   Address    @relation(fields: [addressId], references: [id])
  addressId String
  customers Customer[]
}

model InvoiceEntry {
  id          String    @id @default(uuid())
  startTime   DateTime?
  endTime     DateTime?
  description String
  amount      Int
  quantity    Float     @default(1)
  billed      Boolean   @default(false)
  type        String    @default("bill")
  customer    Customer  @relation(fields: [customerId], references: [id])
  customerId  String
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
  invoiceId   String?
  invoiceGroup   InvoiceGroup? @relation(fields: [invoiceGroupId], references: [id])
  invoiceGroupId String?
  // Snapshot of the group's invoiceDescription, frozen onto the entry when it is
  // billed onto an invoice so later edits to the group don't alter past invoices.
  invoiceGroupLabel String?
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
}

model Address {
  id               String            @id @default(uuid())
  street1          String
  street2          String?
  city             String
  region           String
  postalCode       String
  customer         Customer?
  serviceProviders ServiceProvider[]
}

model Customer {
  id                    String                 @id @default(uuid())
  name                  String
  addressId             String                 @unique
  address               Address                @relation(fields: [addressId], references: [id])
  invoices              Invoice[]
  invoiceEntries        InvoiceEntry[]
  invoiceGroups         InvoiceGroup[]
  schedules             InvoiceEntrySchedule[]
  serviceProvider       ServiceProvider        @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId     String
  startingInvoiceNumber Int                    @default(1)
  defaultEntryAmount    Int                    @default(0)
}

model Invoice {
  id             String         @id @default(uuid())
  date           DateTime
  invoiceNumber  Int
  status         String         @default("open")
  customer       Customer       @relation(fields: [customerId], references: [id])
  customerId     String
  invoiceEntries InvoiceEntry[]
  fileLocation   String?
  createdAt      DateTime       @default(now())

  @@unique([customerId, invoiceNumber])
}

model InvoiceEntrySchedule {
  id          String    @id @default(uuid())
  cron        String
  description String
  amount      Int
  quantity    Float     @default(1)
  type        String    @default("bill")
  active      Boolean   @default(true)
  customer    Customer  @relation(fields: [customerId], references: [id])
  customerId  String
  invoiceGroup   InvoiceGroup? @relation(fields: [invoiceGroupId], references: [id])
  invoiceGroupId String?
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
}

model InvoiceGroup {
  id                 String                 @id @default(uuid())
  name               String
  invoiceDescription String
  customer           Customer               @relation(fields: [customerId], references: [id])
  customerId         String
  entries            InvoiceEntry[]
  schedules          InvoiceEntrySchedule[]
  createdAt          DateTime               @default(now())
}
